FROM python:3.12-slim

WORKDIR /app

# Install uv
RUN pip install uv mcp-proxy

# Copy MCP server files
COPY . .

# Install dependencies
RUN uv sync --frozen

# Expose SSE port
EXPOSE 8080

# Run with HTTP/SSE transport via mcp-proxy
CMD ["mcp-proxy", "--port", "8080", "--", "uv", "run", "--frozen", "start"]